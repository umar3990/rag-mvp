<% content_for :title, "Conversations" %>

<div class="flex items-center justify-between">
  <h1 class="text-lg font-semibold text-gray-900">Conversations</h1>
  <%= button_to "New conversation", conversations_path, method: :post,
        class: "rounded-md bg-gray-900 px-3 py-2 text-sm font-semibold text-white hover:bg-gray-700" %>
</div>

<div class="mt-6 divide-y divide-gray-200 rounded-lg border border-gray-200 bg-white">
  <% if @conversations.empty? %>
    <p class="p-6 text-sm text-gray-500">No conversations yet.</p>
  <% end %>

  <% @conversations.each do |conversation| %>
    <%= link_to conversation_path(conversation), class: "block p-4 hover:bg-gray-50" do %>
      <p class="text-sm font-medium text-gray-900">
        Conversation started <%= time_ago_in_words(conversation.created_at) %> ago
      </p>
      <p class="text-xs text-gray-500"><%= pluralize(conversation.messages.count, "message") %></p>
    <% end %>
  <% end %>
</div>

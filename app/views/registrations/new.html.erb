<% content_for :title, "Sign up" %>

<div class="mx-auto max-w-sm">
  <h1 class="text-xl font-semibold text-gray-900">Create your workspace</h1>
  <p class="mt-1 text-sm text-gray-500">One organization, one account to start.</p>

  <% if @organization.errors.any? %>
    <div class="mt-6 rounded-md bg-red-50 px-4 py-3 text-sm text-red-800">
      <ul class="list-inside list-disc">
        <% @organization.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: registration_path, class: "mt-6 space-y-4" do |form| %>
    <div>
      <%= form.label :organization_name, "Organization name", class: "block text-sm font-medium text-gray-700" %>
      <%= text_field_tag "organization[name]", @organization.name, id: "organization_name", required: true,
            class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-gray-500 focus:outline-none focus:ring-1 focus:ring-gray-500" %>
    </div>

    <div>
      <%= form.label :user_email_address, "Email", class: "block text-sm font-medium text-gray-700" %>
      <%= email_field_tag "user[email_address]", @user.email_address, id: "user_email_address", required: true, autocomplete: "email",
            class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-gray-500 focus:outline-none focus:ring-1 focus:ring-gray-500" %>
    </div>

    <div>
      <%= form.label :user_password, "Password", class: "block text-sm font-medium text-gray-700" %>
      <%= password_field_tag "user[password]", nil, id: "user_password", required: true, autocomplete: "new-password",
            class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-gray-500 focus:outline-none focus:ring-1 focus:ring-gray-500" %>
    </div>

    <div>
      <%= form.label :user_password_confirmation, "Confirm password", class: "block text-sm font-medium text-gray-700" %>
      <%= password_field_tag "user[password_confirmation]", nil, id: "user_password_confirmation", required: true, autocomplete: "new-password",
            class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-gray-500 focus:outline-none focus:ring-1 focus:ring-gray-500" %>
    </div>

    <%= form.submit "Create workspace", class: "w-full cursor-pointer rounded-md bg-gray-900 px-3 py-2 text-sm font-semibold text-white hover:bg-gray-700" %>
  <% end %>

  <p class="mt-6 text-center text-sm text-gray-500">
    Already have an account?
    <%= link_to "Sign in", new_session_path, class: "font-medium text-gray-900 hover:underline" %>
  </p>
</div>

<% content_for :title, "Forgot password" %>

<div class="mx-auto max-w-sm">
  <h1 class="text-xl font-semibold text-gray-900">Forgot your password?</h1>
  <p class="mt-1 text-sm text-gray-500">We'll email you a link to reset it.</p>

  <%= form_with url: passwords_path, class: "mt-6 space-y-4" do |form| %>
    <div>
      <%= form.label :email_address, "Email", class: "block text-sm font-medium text-gray-700" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address],
            class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-gray-500 focus:outline-none focus:ring-1 focus:ring-gray-500" %>
    </div>

    <%= form.submit "Email reset instructions", class: "w-full cursor-pointer rounded-md bg-gray-900 px-3 py-2 text-sm font-semibold text-white hover:bg-gray-700" %>
  <% end %>

  <p class="mt-6 text-center text-sm text-gray-500">
    <%= link_to "Back to sign in", new_session_path, class: "font-medium text-gray-900 hover:underline" %>
  </p>
</div>

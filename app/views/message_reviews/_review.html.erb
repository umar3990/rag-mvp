<div id="<%= dom_id(message, :review) %>" class="rounded-lg border border-gray-200 bg-white p-6">
  <div class="flex items-center justify-between">
    <p class="text-sm font-medium text-gray-900"><%= message.conversation.from_email %></p>
    <% if message.escalated? %>
      <span class="rounded-full bg-amber-50 px-2 py-1 text-xs font-medium text-amber-700">Low confidence -- nothing found</span>
    <% end %>
  </div>
  <p class="mt-1 text-xs text-gray-500">Received <%= time_ago_in_words(message.question&.created_at || message.created_at) %> ago</p>

  <div class="mt-4 rounded-md bg-gray-50 p-3 text-sm text-gray-700">
    <p class="text-xs font-medium text-gray-500">Question</p>
    <p class="mt-1 whitespace-pre-wrap"><%= message.question&.content %></p>
  </div>

  <%= form_with url: approve_review_path(message), method: :patch, class: "mt-4" do |form| %>
    <label class="block text-xs font-medium text-gray-500">Draft reply</label>
    <%= form.text_area :content, value: message.content, rows: 4,
          class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-gray-500 focus:outline-none focus:ring-1 focus:ring-gray-500" %>

    <% if message.source_documents.any? %>
      <p class="mt-2 text-xs text-gray-500">
        Sources:
        <%= safe_join(message.source_documents.map { |document| link_to(document.title, document_path(document), class: "underline") }, ", ") %>
      </p>
    <% end %>

    <%= form.submit "Approve", class: "mt-3 cursor-pointer rounded-md bg-gray-900 px-4 py-2 text-sm font-semibold text-white hover:bg-gray-700" %>
  <% end %>

  <%# Its own <form> from button_to -- must be a sibling of, not nested
      inside, the Approve form above. Nested <form> elements are invalid
      HTML; the browser collapses them and clicking Reject would submit
      the outer Approve form instead. %>
  <%= button_to "Reject", reject_review_path(message), method: :patch,
        class: "mt-3 rounded-md border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50" %>
</div>

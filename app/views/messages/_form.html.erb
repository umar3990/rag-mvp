<div id="new_message_form">
  <%= form_with model: message, url: conversation_messages_path(conversation), class: "flex gap-3" do |form| %>
    <%= form.text_field :content, required: true, autofocus: true, autocomplete: "off",
          placeholder: "Ask a question...",
          class: "flex-1 rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-gray-500 focus:outline-none focus:ring-1 focus:ring-gray-500" %>
    <%= form.submit "Send", class: "cursor-pointer rounded-md bg-gray-900 px-4 py-2 text-sm font-semibold text-white hover:bg-gray-700" %>
  <% end %>

  <% if message.errors.any? %>
    <p class="mt-2 text-sm text-red-600"><%= message.errors.full_messages.to_sentence %></p>
  <% end %>
</div>

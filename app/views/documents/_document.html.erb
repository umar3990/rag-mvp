<div id="<%= dom_id(document) %>" class="flex items-center justify-between p-4 hover:bg-gray-50">
  <%= link_to document_path(document), class: "flex-1" do %>
    <p class="text-sm font-medium text-gray-900"><%= document.title %></p>
    <p class="text-xs text-gray-500">
      Uploaded <%= time_ago_in_words(document.created_at) %> ago
      <% if document.user %> by <%= document.user.email_address %><% end %>
    </p>
  <% end %>

  <div class="flex items-center gap-3">
    <span class="rounded-full px-2 py-1 text-xs font-medium
      <%= document.completed? ? "bg-green-50 text-green-700" : document.failed? ? "bg-red-50 text-red-700" : "bg-gray-100 text-gray-600" %>">
      <%= document.status %>
    </span>

    <% if document.failed? %>
      <%= button_to retry_document_path(document), method: :post,
            class: "text-gray-400 hover:text-gray-700", title: "Retry" do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
        </svg>
      <% end %>
    <% end %>
  </div>
</div>

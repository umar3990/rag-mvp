<% content_for :title, @document.title %>

<%= link_to "← Documents", documents_path, class: "text-sm text-gray-500 hover:underline" %>

<div class="mt-4 rounded-lg border border-gray-200 bg-white p-6">
  <div class="flex items-center justify-between">
    <h1 class="text-lg font-semibold text-gray-900"><%= @document.title %></h1>
    <span class="rounded-full px-2 py-1 text-xs font-medium
      <%= @document.completed? ? "bg-green-50 text-green-700" : @document.failed? ? "bg-red-50 text-red-700" : "bg-gray-100 text-gray-600" %>">
      <%= @document.status %>
    </span>
  </div>
  <p class="mt-1 text-sm text-gray-500">
    <%= @document.file.filename %> (<%= number_to_human_size(@document.file.byte_size) %>)
  </p>
</div>

# Copy this file to .env and fill in real values. .env is gitignored —
# never commit real keys.

# Postgres connection (matches docker-compose.yml)
DATABASE_URL=postgres://rag_mvp:rag_mvp@localhost:5433/rag_mvp_development

# Embeddings + chat completion both run locally via Ollama -- $0 cost, no
# API key, no card on file. Ollama runs natively on the host (see
# notes.md / com.ollama.serve.plist), not in Docker.
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2:3b

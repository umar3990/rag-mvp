# Copy this file to .env and fill in real values. .env is gitignored —
# never commit real keys.

# Postgres connection (matches docker-compose.yml)
DATABASE_URL=postgres://rag_mvp:rag_mvp@localhost:5433/rag_mvp_development

# Used for chat completion (Day 5+). Get one from console.anthropic.com
# or platform.openai.com depending which we pick.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Embeddings run locally via Ollama (docker-compose service `ollama`) --
# $0 cost, no API key needed. Matches the port Compose publishes to the
# host (11434:11434).
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

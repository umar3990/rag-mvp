# Copy this file to .env.test. dotenv-rails loads .env.test instead of
# .env when RAILS_ENV=test, so the test suite never touches the
# development database — using the same DATABASE_URL for both is what
# caused test runs to truncate/reload fixtures into dev data by mistake.
#
# Different database name (rag_mvp_test), same Postgres container/port.
DATABASE_URL=postgres://rag_mvp:rag_mvp@localhost:5433/rag_mvp_test
